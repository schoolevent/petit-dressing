{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "petit-dressing",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-07-19",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB"
    }
  ]
}
